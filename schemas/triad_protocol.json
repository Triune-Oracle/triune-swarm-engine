                "Communicates via oracle.inference.<study_id>"
            ]
        },
        "GEMINI": {
            "namespace": "namespace_d",
            "role": "Resource Orchestration",
            "functions": [
                "Schedules inference resource allocation",
                "Maintains batch coherence",
                "Coordinates namespace communication"
            ]
        },
        "CAPRI": {
            "namespace": "namespace_b",
            "role": "Decision Audit Logging",
            "functions": [
                "Writes immutable audit log entries",
                "Records confidence scores per inference batch",
                "Reports via audit.<study_id>"
            ]
        },
        "ARIA": {
            "namespace": "namespace_c",
            "role": "IPFS Metadata & Provenance",
            "functions": [
                "Maintains provenance metadata on IPFS",
                "Indexes study and batch records",
                "No PHI — metadata only"
            ]
        }
    },
    "reconstruction_metrics": {
        "echoDepth": {
            "description": "VAE latent space traversal depth",
