            "clinical_threshold": 0.60
        },
        "affectFootprint": {
            "description": "Uncertainty quantification — pixel-wise variance heatmap magnitude",
            "range": [0, 1],
            "alert_threshold": 0.30
        },
        "resonantDrift": {
            "description": "Model drift detection across inference batches",
            "range": [0, 0.5],
            "alert_threshold": 0.10
        }
    },
    "confidence_score": 0.94,
